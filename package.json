{
  "name": "dweeb",
  "private": true,
  "version": "0.8.0",
  "type": "module",
  "description": "DWEEB — a visual Discord webhook & embed builder for Components V2 messages. Build, preview, and send Discord messages without writing JSON. Private by design (runs entirely in your browser, nothing uploaded), source-available, and built for large communities and teams.",
  "license": "PolyForm-Noncommercial-1.0.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host",
    "typecheck": "tsc -b --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\""
  },
  "dependencies": {
    "lz-string": "^1.5.0",
    "preact": "^10.29.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/node": "^20.16.10",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react-swc": "^3.7.1",
    "prettier": "^3.3.3",
    "terser": "^5.48.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vite-plugin-pwa": "^0.21"
  },
  "engines": {
    "bun": ">=1.1.0",
    "node": ">=20"
  }
}
