node_modules
dist
.DS_Store
*.log
.env
.env.local
.env.*.local
.env.production
.vite
.cache
bun.lockb
# Bun is the canonical package manager (see engines + CI). Ignore npm's
# lockfile so an `npm install` by a contributor doesn't create a second
# lockfile and trip VS Code's "multiple lockfiles" warning.
package-lock.json
# TypeScript incremental-build cache — regenerated on every build.
*.tsbuildinfo
# Local-only release-announcement artifacts (webhook payload + screenshots).
release/
# Local backup of the production stack from contabo:/opt/dweeb (contains secrets).
prod-backup/
# Runtime SQLite state (the proxy's short links + each plugin's config/ledger).
# These are created at run time and live on Docker volumes in production — they
# must never be committed (live data, and they'd ship stale into images).
*.db
*.db-wal
*.db-shm

# Local mkcert dev certificates for HTTPS (Discord Activity local dev)
certs/

# Private cross-tool agent context (deployment/ops facts) — public repo, never commit.
AGENTS.local.md
CLAUDE.local.md
