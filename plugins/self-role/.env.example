# Self Role plugin — configuration.

# Your Discord application's PUBLIC KEY (Developer Portal → General Information).
# 64 hex chars. Used to verify interaction signatures. Required.
#
# NOTE: this is the *app* that owns the webhook the menu is posted through (the
# DWEEB app, or a guild's custom app). It is NOT the bot that assigns roles —
# that is the deployment-wide shared bot (BOT_TOKEN below). The two can be the
# same app or different apps.
DISCORD_PUBLIC_KEY=

# The public origin this service is reachable at (no trailing slash). DWEEB
# embeds `${PUBLIC_BASE_URL}/config.html` and the registry advertises it.
PUBLIC_BASE_URL=http://localhost:8092

# Shared secret with the interactions dispatcher (DISPATCHER_FORWARD_SECRET
# there too). It vouches for the x-dweeb-public-key header the dispatcher
# forwards, letting this plugin verify interactions from guild-registered
# CUSTOM apps with the right key. Optional; leave blank and only the primary
# key above ever verifies.
DISPATCHER_FORWARD_SECRET=

# The deployment-wide "Self Role" bot token (with Manage Roles). This shared bot
# does ALL role assignment — server admins just invite it; no one ever pastes a
# token. The service starts without this, but the config UI then refuses to set
# up a menu (and clicks reply "no bot connected"), so it's required in practice.
# SECRET — never logged or returned to a browser.
BOT_TOKEN=

# OPTIONAL — the OAuth invite link for the shared bot above (scope=bot).
# Surfaced in the config UI as a one-click "Add the bot to your server" button;
# the UI shows generic guidance if blank. You only need the right app's
# client_id — the `permissions` are rewritten on startup to the shared union
# every DWEEB invite must carry (Discord *replaces* a bot's permissions on
# re-invite, so a narrower link would strip what other plugins granted). Example:
# https://discord.com/oauth2/authorize?client_id=APP_ID&scope=bot&permissions=268435456
BOT_INVITE_URL=

# Port to bind. Default 8092.
PORT=8092

# SQLite file path. Default ./self-role.db. On a host with a persistent disk,
# point this at the mounted volume so configs survive restarts.
DATABASE_PATH=./self-role.db

# OPTIONAL — how often (seconds) the temporary-role reaper wakes to take back
# expired roles. Default 30, clamped to a 5s floor. Lower it in dev to watch
# auto-removal happen quickly; raise it to ease load on a busy deployment.
REAPER_INTERVAL_SECS=30

# Optional: log level (e.g. info, debug, dweeb_self_role=debug).
RUST_LOG=info
