# Giveaway plugin — configuration.

# Your Discord application's PUBLIC KEY (Developer Portal → General Information).
# 64 hex chars. Used to verify interaction signatures. Required.
#
# NOTE: this is the *app* that owns the webhook the giveaway is posted through
# (the DWEEB app, or a guild's custom app). It is NOT a bot token — the giveaway
# runs its whole lifecycle off interaction responses.
DISCORD_PUBLIC_KEY=

# The public origin this service is reachable at (no trailing slash). DWEEB
# embeds `${PUBLIC_BASE_URL}/config.html` and the registry advertises it.
PUBLIC_BASE_URL=http://localhost:8094

# Shared secret with the interactions dispatcher (DISPATCHER_FORWARD_SECRET
# there too). It vouches for the x-dweeb-public-key header the dispatcher
# forwards, letting this plugin verify interactions from guild-registered
# CUSTOM apps with the right key. Optional; leave blank and only the primary
# key above ever verifies.
DISPATCHER_FORWARD_SECRET=

# OPTIONAL — the deployment-wide shared bot token. The giveaway needs NO bot to
# run: entering, the live count, the draw and the announcement all happen over
# interaction responses. This token only powers two extras:
#   • listing a guild's roles in the config UI's requirement / host-role picker;
#   • DMing the winners when a giveaway has "DM winners" turned on.
# Leave it blank and those two features are simply disabled (the UI says so).
# SECRET — never logged or returned to a browser.
BOT_TOKEN=

# OPTIONAL — the OAuth invite link for the shared bot above (scope=bot).
# Surfaced in the config UI as a one-click "Add the bot to your server" button.
# You only need the right app's client_id — the `permissions` are rewritten on
# startup to the shared union every DWEEB invite must carry (Discord *replaces*
# a bot's permissions on re-invite, so a narrower link would strip what other
# plugins granted). Example:
# https://discord.com/oauth2/authorize?client_id=APP_ID&scope=bot&permissions=0
BOT_INVITE_URL=

# Port to bind. Default 8094.
PORT=8094

# SQLite file path. Default ./giveaway.db. On a host with a persistent disk,
# point this at the mounted volume so giveaways + entries survive restarts.
DATABASE_PATH=./giveaway.db

# Optional: log level (e.g. info, debug, dweeb_giveaway=debug).
RUST_LOG=info
