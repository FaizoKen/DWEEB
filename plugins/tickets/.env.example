# Tickets plugin — configuration.

# Your Discord application's PUBLIC KEY (Developer Portal → General Information).
# 64 hex chars. Used to verify interaction signatures. Required.
#
# NOTE: this is the *app* that owns the webhook the panel is posted through (the
# DWEEB app, or a guild's custom app). It is NOT the bot that creates the ticket
# channels — that is the deployment-wide shared bot (BOT_TOKEN below). The two
# can be the same app or different apps.
DISCORD_PUBLIC_KEY=

# The public origin this service is reachable at (no trailing slash). DWEEB
# embeds `${PUBLIC_BASE_URL}/config.html` and the registry advertises it.
PUBLIC_BASE_URL=http://localhost:8093

# Shared secret with the interactions dispatcher (DISPATCHER_FORWARD_SECRET
# there too). It vouches for the x-dweeb-public-key header the dispatcher
# forwards, letting this plugin verify interactions from guild-registered
# CUSTOM apps with the right key. Optional; leave blank and only the primary
# key above ever verifies.
DISPATCHER_FORWARD_SECRET=

# The deployment-wide "Tickets" bot token. This shared bot creates and deletes
# the per-ticket channels, sets their permission overwrites, posts the welcome
# + controls, and writes transcripts — so it needs MANAGE CHANNELS and MANAGE
# ROLES (the latter to set channel permission overwrites). Server admins just
# invite it; no one ever pastes a token. The service starts without this, but
# the config UI then refuses to set up a panel (and clicks reply "no bot
# connected"), so it's required in practice. SECRET — never logged or returned
# to a browser.
BOT_TOKEN=

# OPTIONAL — the OAuth invite link for the shared bot above (scope=bot).
# Surfaced in the config UI as a one-click "Add the bot to your server" button;
# the UI shows generic guidance if blank. You only need the right app's
# client_id — the `permissions` are rewritten on startup to the shared union
# every DWEEB invite must carry (Discord *replaces* a bot's permissions on
# re-invite, so a narrower link would strip what other plugins granted). The
# union is Manage Channels + Manage Roles = 268435472. Example:
# https://discord.com/oauth2/authorize?client_id=APP_ID&scope=bot&permissions=268435472
BOT_INVITE_URL=

# Port to bind. Default 8093.
PORT=8093

# SQLite file path. Default ./tickets.db. On a host with a persistent disk,
# point this at the mounted volume so configs + open tickets survive restarts.
DATABASE_PATH=./tickets.db

# Optional: log level (e.g. info, debug, dweeb_tickets=debug).
RUST_LOG=info
