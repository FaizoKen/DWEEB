# Interactions dispatcher — configuration.

# Your Discord application's PUBLIC KEY (Developer Portal → General Information).
# 64 hex chars. Used to verify interaction signatures. Required.
DISCORD_PUBLIC_KEY=

# JSON map of custom_id prefix → upstream plugin base URL. Required.
# Longest prefix wins. In compose these are service names (http://modal-form:8090);
# for local dev point at the plugins' localhost ports. Keep the single quotes —
# dotenvy needs them to take the JSON (with its own double quotes) literally.
ROUTES='{"modalform:": "http://localhost:8090", "pingpong:": "http://localhost:8091"}'

# Days a component stays clickable after its message was sent.
# Default 7; 0 = never expires.
COMPONENT_TTL_DAYS=7

# TTL-exempt messages each guild may hold. Default 2; 0 stops new grants
# (existing ones stay honored).
PERMANENT_SLOTS_PER_GUILD=2

# Custom Discord apps each guild may register (default 1) — the dispatcher
# then serves THEIR app's interactions too, verified with the registered
# app's own public key. 0 stops new registrations (existing ones keep
# working). Per-guild plan caps can replace this deployment-wide default
# later; the API responses already carry the cap.
CUSTOM_APPS_PER_GUILD=1

# Shared secret with every plugin: vouches for the x-dweeb-public-key header
# forwarded alongside an interaction, so plugins can re-verify custom-app
# signatures with the right key. Must match DISPATCHER_FORWARD_SECRET on the
# plugins. Leave blank and custom-app interactions fail the plugins' own
# verification. Generate one with e.g.: openssl rand -hex 32
DISPATCHER_FORWARD_SECRET=

# Bearer token gating the /permanent and /custom-apps management APIs the
# proxy calls. Leave blank to disable those APIs. Generate one with e.g.:
# openssl rand -hex 32
INTERNAL_API_TOKEN=

# SQLite file for the permanent slots + custom-app registry.
# Default ./dispatcher.db (/data/dispatcher.db in the image).
DATABASE_PATH=./dispatcher.db

# URL the /dashboard slash command replies with. Default https://dweeb.faizo.net;
# for local dev point at the Vite dev server.
DASHBOARD_URL=https://dweeb.faizo.net

# Proxy base URL the dispatcher calls to revive a message's TTL-disabled
# components after granting it a never-expire slot (POST
# /internal/permanent/reenable). The dispatcher holds no webhook token, so the
# proxy — which does — performs the edit; authenticated with INTERNAL_API_TOKEN
# in reverse. Default http://proxy:8080 (the compose service); if unreachable
# the grant still succeeds, just without reviving the buttons.
SERVER_URL=http://proxy:8080

# Port to bind. Default 8095 (what Caddy and the compose healthcheck expect).
PORT=8095

# Optional: log level (e.g. info, debug, dweeb_interactions_dispatcher=debug).
RUST_LOG=info
