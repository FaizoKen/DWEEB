# Modal Form plugin — configuration.

# Your Discord application's PUBLIC KEY (Developer Portal → General Information).
# 64 hex chars. Used to verify interaction signatures. Required.
DISCORD_PUBLIC_KEY=

# The public origin this service is reachable at (no trailing slash). DWEEB
# embeds `${PUBLIC_BASE_URL}/config.html` and the registry advertises it.
# For local dev with the stub flow this is http://localhost:8090.
PUBLIC_BASE_URL=http://localhost:8090

# Port to bind. Default 8090.
PORT=8090

# SQLite file path. Default ./modal-form.db. On a host with a persistent disk,
# point this at the mounted volume so configs survive restarts.
DATABASE_PATH=./modal-form.db

# Optional: log level (e.g. info, debug, dweeb_modal_form=debug).
RUST_LOG=info
