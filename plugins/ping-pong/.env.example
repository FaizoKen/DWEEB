# Ping Pong plugin — configuration.

# Your Discord application's PUBLIC KEY (Developer Portal → General Information).
# 64 hex chars. Used to verify interaction signatures. Required.
DISCORD_PUBLIC_KEY=

# The public origin this service is reachable at (no trailing slash). DWEEB
# embeds `${PUBLIC_BASE_URL}/config.html` and the registry advertises it.
# For local dev this is http://localhost:8091.
PUBLIC_BASE_URL=http://localhost:8091

# Shared secret with the interactions dispatcher (DISPATCHER_FORWARD_SECRET
# there too). It vouches for the x-dweeb-public-key header the dispatcher
# forwards, letting this plugin verify interactions from guild-registered
# CUSTOM apps with the right key. Optional; leave blank and only the primary
# key above ever verifies.
DISPATCHER_FORWARD_SECRET=

# Port to bind. Default 8091 (so it can run next to modal-form's 8090 locally).
PORT=8091

# Optional: log level (e.g. info, debug, dweeb_ping_pong=debug).
RUST_LOG=info
