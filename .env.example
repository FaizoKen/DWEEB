# DWEEB frontend — build-time configuration (Vite).
#
# Copy to `.env.local` (git-ignored) and fill in to enable the "Server data"
# panel, which signs the user in with Discord and loads a server's roles,
# channels, and custom emoji through the proxy in `server/`. Leave
# VITE_PROXY_BASE_URL blank and the app runs as a pure client-side builder with
# no server calls (mentions render as neutral placeholders).
#
# These are inlined into the client bundle at build time, so only put PUBLIC
# values here. Restart `vite` after changing them.

# Base URL of the DWEEB proxy (no trailing slash). For local dev this is the
# Rust service from `server/` (default 0.0.0.0:8080):
#   VITE_PROXY_BASE_URL=http://localhost:8080
# In production, the public hostname your proxy is reachable at. Hosting it on a
# subdomain of the builder's site (e.g. api.dweeb.example.com next to
# dweeb.example.com) keeps the session cookie same-site:
#   VITE_PROXY_BASE_URL=https://api.dweeb.example.com
VITE_PROXY_BASE_URL=

# Discord application (client) id — the public id from the Developer Portal.
# Used only to build the "Add DWEEB to your server" invite link.
#
# The invite returns the user to this site after they add the bot, so register
# the builder's URL (e.g. https://dweeb.example.com, or http://localhost:5173
# for dev) as an OAuth2 redirect URI in the Developer Portal. Discord rejects
# the invite if the redirect URI isn't registered.
VITE_DISCORD_CLIENT_ID=
