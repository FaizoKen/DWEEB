# DWEEB frontend — build-time configuration (Vite).
#
# Copy to `.env.local` (git-ignored) when you need personal overrides. This
# repository's ordinary local mode can instead keep its shared local defaults
# in `.env`; the Activity override belongs in `.env.activity.local` and runs via
# `bun run dev:activity` so it cannot replace normal login settings. These vars
# enable the "Server data" panel, which signs the user in with Discord and loads
# a server's roles, channels, and custom emoji through the proxy. Leave
# VITE_PROXY_BASE_URL blank and the app runs as a pure client-side builder with
# no server calls (mentions render as neutral placeholders).
#
# These are inlined into the client bundle at build time, so only put PUBLIC
# values here. Restart `vite` after changing them.

# Base URL of the DWEEB proxy (no trailing slash). For local dev this is the
# Rust service from `server/` (default 0.0.0.0:8080):
#   VITE_PROXY_BASE_URL=http://localhost:8080
# In production, the public hostname your proxy is reachable at. Hosting it on a
# subdomain of the builder's site (e.g. api.dweeb.example.com next to
# dweeb.example.com) keeps the session cookie same-site:
#   VITE_PROXY_BASE_URL=https://api.dweeb.example.com
VITE_PROXY_BASE_URL=

# Discord application (client) id — the public id from the Developer Portal.
# Used only to build the "Add DWEEB to your server" invite link.
#
# The invite returns the user to this site after they add the bot, so register
# the builder's URL (e.g. https://dweeb.example.com, or http://localhost:5173
# for dev) as an OAuth2 redirect URI in the Developer Portal. Discord rejects
# the invite if the redirect URI isn't registered.
VITE_DISCORD_CLIENT_ID=

# Discord Activity (embedded app) — reuses VITE_PROXY_BASE_URL (its proxy origin
# becomes the in-Discord URL-mapping target) and VITE_DISCORD_CLIENT_ID (the SDK
# + OAuth handshake). The only setup is in the Developer Portal (URL mappings +
# scopes) and on the proxy (ACTIVITIES_ENABLED). See docs/activity.md.
#
# Optional: canonical public URL of the web app, used by the Activity's "Open on
# web" hand-off (inside Discord, window.location is the sandbox origin, not the
# site). Defaults to https://dweeb.faizo.net; override for your own deployment:
#   VITE_WEB_APP_URL=https://dweeb.example.com
VITE_WEB_APP_URL=

# Interactions Endpoint URL shown in the dashboard's "Custom bot" dialog — the
# URL a server owner pastes into THEIR OWN Discord app so the DWEEB dispatcher
# serves its interactions. Optional: when blank, the dialog shows
# `$VITE_PROXY_BASE_URL/interactions` (the bundled Caddyfile rewrites that
# alias to the dispatcher). Set it when the dispatcher has its own hostname:
#   VITE_INTERACTIONS_URL=https://interactions.dweeb.example.com
VITE_INTERACTIONS_URL=

# Stripe publishable key (pk_live_… / pk_test_…) for the in-app embedded Checkout
# in the pricing modal. Leave blank and the pricing modal is informational only
# (no in-app upgrade). Pairs with the backend's STRIPE_SECRET_KEY /
# STRIPE_WEBHOOK_SECRET (see server/.env.example).
#   VITE_STRIPE_PUBLISHABLE_KEY=pk_live_xxx
VITE_STRIPE_PUBLISHABLE_KEY=

# Days a message's interactive components (buttons / select menus) stay
# clickable after sending before the dispatcher stops answering them — unless
# the message claims a never-expire slot. MUST mirror the dispatcher's
# COMPONENT_TTL_DAYS (see plugins/dispatcher/.env.example; default 7, 0 = never
# expires). Used to tell signed-out users the exact expiry in the pre-send
# confirm dialog, where the live figure (behind the authed slot fetch) isn't
# available. Blank → assumes the dispatcher default of 7.
VITE_COMPONENT_TTL_DAYS=

# Plugins are configured in source, not via env. The list of installable plugin
# manifests is bundled at build time from `src/core/plugins/registry.json`:
# interactive components (buttons with a custom_id, select menus) gain a
# "Plugin" panel in the inspector whenever that file lists at least one plugin.
# Add or remove a plugin by editing `registry.json` and rebuilding the web app;
# an empty `plugins` array disables the feature entirely. See `docs/plugins.md`
# for the manifest fields and the iframe protocol.
#
# In `vite` dev, each plugin's config UI is automatically pointed at the local
# microservice you run with `cargo run` in `plugins/<id>` (ports :8090-:8097,
# excluding the dispatcher on :8095) instead of the production hostname in
# `registry.json`.
# Override a port only if you run a plugin somewhere else:
#   VITE_DEV_MODAL_FORM_ORIGIN=http://localhost:8090
#   VITE_DEV_PING_PONG_ORIGIN=http://localhost:8091
VITE_DEV_MODAL_FORM_ORIGIN=
VITE_DEV_PING_PONG_ORIGIN=
VITE_DEV_SELF_ROLE_ORIGIN=
VITE_DEV_TICKETS_ORIGIN=
VITE_DEV_GIVEAWAY_ORIGIN=
VITE_DEV_QUICK_REPLIES_ORIGIN=
VITE_DEV_PICKER_ORIGIN=
VITE_DEV_POLL_ORIGIN=
