{
  // Editor / optional type-check project for the test suite. The production
  // build (`tsc -b` → tsconfig.app.json) EXCLUDES `*.test.ts` so it stays fast
  // and free of test-only types; this config re-includes them with Vitest's
  // globals available, so an IDE type-checks tests against the same strict
  // options the app uses. Vitest itself transpiles per-file via esbuild and
  // does not run this.
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "types": ["vitest/globals", "node"],
    "noEmit": true
  },
  "include": ["src", "src/test", "vitest.config.ts"]
}
