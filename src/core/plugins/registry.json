{
  "schemaVersion": 1,
  "plugins": [
    {
      "schemaVersion": 1,
      "id": "modal-form",
      "name": "Modal Form",
      "description": "Pop up a form on click, forward the answers to a channel (named or anonymous), and reply privately. Optional one-response-per-person.",
      "version": "0.2.0",
      "publisher": "DWEEB",
      "homepage": "https://github.com/FaizoKen/DWEEB/tree/main/plugins/modal-form",
      "targets": ["button"],
      "configUrl": "https://modalform.dweeb.faizo.net/config.html",
      "customIdPrefix": "modalform:"
    },
    {
      "schemaVersion": 1,
      "id": "ping-pong",
      "name": "Latency Check",
      "description": "Reply with your message plus a detailed latency report (click → server, dispatcher hop, handler time).",
      "version": "0.2.0",
      "publisher": "DWEEB",
      "homepage": "https://github.com/FaizoKen/DWEEB/tree/main/plugins/ping-pong",
      "targets": ["button"],
      "configUrl": "https://pingpong.dweeb.faizo.net/config.html",
      "customIdPrefix": "pingpong:"
    },
    {
      "schemaVersion": 1,
      "id": "self-role",
      "name": "Self Role",
      "description": "Let members give themselves roles from a button or select menu — toggle, give, take, or pick-one.",
      "version": "0.1.0",
      "publisher": "DWEEB",
      "homepage": "https://github.com/FaizoKen/DWEEB/tree/main/plugins/self-role",
      "targets": ["button", "string_select"],
      "configUrl": "https://selfrole.dweeb.faizo.net/config.html",
      "customIdPrefix": "selfrole:",
      "managesSelectOptions": true,
      "managesFields": ["min_values", "max_values"],
      "placeholders": [{ "token": "roles", "label": "Roles", "sample": "the role" }]
    },
    {
      "schemaVersion": 1,
      "id": "tickets",
      "name": "Tickets",
      "description": "Private support tickets from a button or topic menu — per-ticket channel, optional intake form, staff claim, close with transcript.",
      "version": "0.1.0",
      "publisher": "DWEEB",
      "homepage": "https://github.com/FaizoKen/DWEEB/tree/main/plugins/tickets",
      "targets": ["button", "string_select"],
      "configUrl": "https://tickets.dweeb.faizo.net/config.html",
      "customIdPrefix": "tickets:",
      "managesSelectOptions": true,
      "managesFields": ["min_values", "max_values"]
    },
    {
      "schemaVersion": 1,
      "id": "giveaway",
      "name": "Giveaway",
      "description": "Run a giveaway from a button: live entrant count, entry requirements (role / account age / one-per-person), a fair random draw of N winners, reroll, and cancel.",
      "version": "0.1.0",
      "publisher": "DWEEB",
      "homepage": "https://github.com/FaizoKen/DWEEB/tree/main/plugins/giveaway",
      "targets": ["button"],
      "configUrl": "https://giveaway.dweeb.faizo.net/config.html",
      "customIdPrefix": "giveaway:",
      "placeholders": [
        { "token": "prize", "label": "Prize", "sample": "the prize" },
        { "token": "entries", "label": "Entry count", "sample": "0" },
        { "token": "winners", "label": "Winners", "sample": "TBD" },
        { "token": "winner_count", "label": "Number of winners", "sample": "1" },
        { "token": "host", "label": "Host", "sample": "the host" },
        { "token": "status", "label": "Status", "sample": "open" }
      ]
    },
    {
      "schemaVersion": 1,
      "id": "quick-replies",
      "name": "Quick Replies",
      "description": "Attach canned replies to a button or topic menu — each one sends text, links and {user}/{server} variables privately or publicly, with optional role-gating. No bot needed.",
      "version": "0.1.0",
      "publisher": "DWEEB",
      "homepage": "https://github.com/FaizoKen/DWEEB/tree/main/plugins/quick-replies",
      "targets": ["button", "string_select"],
      "configUrl": "https://quickreplies.dweeb.faizo.net/config.html",
      "customIdPrefix": "quickreplies:",
      "managesSelectOptions": true,
      "managesFields": ["min_values", "max_values"]
    }
  ]
}
