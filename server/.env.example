# ── Discord bot ────────────────────────────────────────────────────────────
# Bot token from https://discord.com/developers/applications → your app → Bot.
# Used to READ a guild's roles/channels/emojis. The bot must be a MEMBER of a
# server for it to be readable, but it does NOT need to be running/online.
DISCORD_BOT_TOKEN=

# ── Discord OAuth (public login) ───────────────────────────────────────────
# From the same application → OAuth2. The proxy gates every read behind a
# Discord login and only returns a server's data to a user who belongs to it,
# which is what makes it safe to expose publicly.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Must EXACTLY match a redirect added under OAuth2 → Redirects, and point at
# this service's /auth/callback:
#   https://api.dweeb.example.com/auth/callback   (prod)
#   http://localhost:8080/auth/callback           (local dev)
OAUTH_REDIRECT_URL=http://localhost:8080/auth/callback
# Where users land after logging in — the builder's URL.
#   https://dweeb.example.com   (prod)   |   http://localhost:5173   (dev)
FRONTEND_URL=http://localhost:5173

# ── Sessions ───────────────────────────────────────────────────────────────
# Secret that the encrypted session cookie is derived from. MUST be ≥64 chars
# and kept private; rotating it logs everyone out. Generate one with e.g.:
#   openssl rand -hex 48
SESSION_SECRET=
# Hours a login lasts before re-auth (default 168 = 7 days).
SESSION_TTL_HOURS=168
# Cookie flags. Keep COOKIE_SECURE=true in production (HTTPS). Set "none" for
# COOKIE_SAMESITE only if the builder and API are on DIFFERENT sites; "lax"
# works (and is safer) when they share a registrable domain via subdomains.
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
# Optional cookie Domain. LEAVE BLANK in almost all cases — a host-only cookie
# (blank) works because the session/state cookies are HttpOnly and only ever
# read by THIS api host. Only set this to share ONE cookie across subdomains,
# and then use the COMMON PARENT of the api and builder, e.g.
#   COOKIE_DOMAIN=.example.com
# A server can only set a cookie for its own host or a parent domain, so setting
# this to the builder's host (e.g. .dweeb.example.com when the api is the
# sibling api.example.com / api-dweeb.example.com) makes the browser DROP the
# cookie — every login then fails with "state mismatch".
COOKIE_DOMAIN=

# ── Server ─────────────────────────────────────────────────────────────────
# Address the proxy listens on inside the container. Leave as-is for Docker.
BIND_ADDR=0.0.0.0:8080

# Browser origins allowed to call the proxy (CORS), comma-separated. Because
# auth uses cookies, "*" is NOT allowed — list the builder's EXACT origin(s):
#   ALLOWED_ORIGINS=https://dweeb.example.com
ALLOWED_ORIGINS=http://localhost:5173

# ── Authorization policy ───────────────────────────────────────────────────
# When true (default), a user may only read servers they OWN or have
# "Manage Server" in — appropriate for a webhook-builder tool. Set false to
# allow any server they're merely a member of.
REQUIRE_MANAGE_GUILD=true

# ── Caching & abuse controls ───────────────────────────────────────────────
# Seconds to cache each guild's data and each user's server list (default 60).
CACHE_TTL_SECS=60
# Per-IP request budget for /api + /auth (sustained rate + burst allowance).
RATE_LIMIT_PER_MIN=60
RATE_LIMIT_BURST=20
# Max simultaneous calls to Discord under the shared bot token (global cap).
DISCORD_MAX_CONCURRENCY=10

# ── Scaling (optional) ─────────────────────────────────────────────────────
# Leave blank for a single instance (in-memory cache + rate limiter). Set a
# Redis URL to SHARE the cache and rate-limit counters across multiple proxy
# instances behind a load balancer. The proxy verifies the connection at boot
# and exits if it can't reach Redis.
#   REDIS_URL=redis://127.0.0.1:6379
#   REDIS_URL=redis://:password@redis-host:6379
REDIS_URL=

# Log verbosity: error | warn | info | debug | trace
RUST_LOG=info
