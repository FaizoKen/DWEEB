# ── Discord bot ────────────────────────────────────────────────────────────
# Bot token from https://discord.com/developers/applications → your app → Bot.
# Used to READ a guild's roles/channels/emojis. The bot must be a MEMBER of a
# server for it to be readable, but it does NOT need to be running/online.
DISCORD_BOT_TOKEN=

# ── Discord OAuth (public login) ───────────────────────────────────────────
# From the same application → OAuth2. The proxy gates every read behind a
# Discord login and only returns a server's data to a user who belongs to it,
# which is what makes it safe to expose publicly.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Must EXACTLY match a redirect added under OAuth2 → Redirects, and point at
# this service's /auth/callback:
#   https://api.dweeb.example.com/auth/callback   (prod)
#   http://localhost:8080/auth/callback           (local dev)
OAUTH_REDIRECT_URL=http://localhost:8080/auth/callback
# Where users land after logging in — the builder's URL.
#   https://dweeb.example.com   (prod)   |   http://localhost:5173   (dev)
FRONTEND_URL=http://localhost:5173

# ── Sessions ───────────────────────────────────────────────────────────────
# Secret that the encrypted session cookie is derived from. MUST be ≥64 chars
# and kept private; rotating it logs everyone out. Generate one with e.g.:
#   openssl rand -hex 48
SESSION_SECRET=
# Hours a login lasts before re-auth (default 168 = 7 days).
SESSION_TTL_HOURS=168
# Cookie flags. Keep COOKIE_SECURE=true in production (HTTPS). Set "none" for
# COOKIE_SAMESITE only if the builder and API are on DIFFERENT sites; "lax"
# works (and is safer) when they share a registrable domain via subdomains.
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
# Optional cookie Domain. LEAVE BLANK in almost all cases — a host-only cookie
# (blank) works because the session/state cookies are HttpOnly and only ever
# read by THIS api host. Only set this to share ONE cookie across subdomains,
# and then use a COMMON PARENT of the api host, e.g. with the api at
# api.dweeb.example.com:
#   COOKIE_DOMAIN=.dweeb.example.com
# A server can only set a cookie for its own host or a parent domain, so any
# value that is NOT a parent of the api host (e.g. .dweeb.example.com when the
# api lives on the sibling api.example.com) makes the browser DROP the
# cookie — every login then fails with "state mismatch".
COOKIE_DOMAIN=

# ── Public TLS edge (Caddy, Docker deploys only) ──────────────────────────
# Domain Caddy terminates TLS for. Its DNS A record must point STRAIGHT at
# this host (Cloudflare proxy OFF / "DNS only") so Let's Encrypt can issue.
#   DOMAIN=api.dweeb.example.com
DOMAIN=
# Email Let's Encrypt sends expiry/problem notices to.
ACME_EMAIL=

# ── Plugins (Docker deploys only) ──────────────────────────────────────────
# Parent domain plugins are served under: each plugin gets its own subdomain,
# https://<id>.$PLUGINS_DOMAIN (e.g. modalform.dweeb.example.com). Add ONE
# wildcard DNS record — *.$PLUGINS_DOMAIN → this host, proxy OFF — and every
# current and future plugin is covered; no per-plugin DNS work.
#   PLUGINS_DOMAIN=dweeb.example.com
PLUGINS_DOMAIN=
# The Discord application's PUBLIC KEY (Developer Portal → General
# Information, 64 hex chars). Shared by the interactions dispatcher and every
# plugin to verify Discord's interaction signatures. The app's Interactions
# Endpoint URL is https://interactions.$PLUGINS_DOMAIN (the dispatcher) — set
# it once, it never changes as plugins are added.
DISCORD_PUBLIC_KEY=
# Days a plugin component stays clickable after its message was sent (default
# 7). The first click on an older message disables that component on the
# message itself — it never reaches a plugin, and a disabled component fires
# no further interactions. Caps the interaction traffic any one message can
# generate over its lifetime. Set 0 to let components work forever.
COMPONENT_TTL_DAYS=7
# How many messages per server may be exempted from that expiry (default 2).
# Managed from the dashboard: after sending a message with plugin components,
# the success dialog offers "Make permanent" to a signed-in user who
# manages the server. Set 0 to stop new grants; already-granted messages stay
# permanent until removed.
PERMANENT_SLOTS_PER_GUILD=2
# How many of their OWN Discord applications each server may register as a
# "custom bot" (default 1) — the dispatcher then serves THEIR app's
# interactions too, so plugin components work on messages sent by their bot.
# Managed from the dashboard's account menu → Custom bot. Set 0 to stop new
# registrations; already-registered apps keep working. (Per-server plan caps
# can replace this deployment-wide default later.)
CUSTOM_APPS_PER_GUILD=1
# Shared secret between the dispatcher and EVERY plugin. The dispatcher
# forwards which public key verified an interaction; this secret is what
# makes plugins trust that header, so they can re-verify custom-app
# signatures themselves. Leave blank and custom-app clicks are refused at
# the plugin hop. Generate one with e.g.:
#   openssl rand -hex 32
DISPATCHER_FORWARD_SECRET=
# Shared secret between the proxy and the dispatcher's management APIs
# (permanent slots + custom-app registry; the proxy calls the dispatcher
# with it on the dashboard's behalf). It also gates the reverse call: the
# dispatcher presents this same token to POST /internal/permanent/reenable
# when its "Never expire" button needs a message's disabled components
# switched back on. Leave blank to disable both features. Generate one with:
#   openssl rand -hex 32
DISPATCHER_API_TOKEN=
# Where the proxy reaches the dispatcher's internal API. compose.yml already sets
# this to the service address on the internal network, so leave it unset for
# Docker. Only needed when running the two outside compose. Unset (with no
# compose default) ⇒ the permanent-slot endpoints answer 501.
#   DISPATCHER_URL=http://dispatcher:8095

# ── Plugin bots (Docker deploys only) ──────────────────────────────────────
# Two bundled plugins call the Discord REST API with the SHARED DWEEB bot, so
# they need its token. Both are REQUIRED by compose.yml (it refuses to start
# until they're set) — point each at the main bot above. They are NOT given
# empty defaults here on purpose: an empty value would also fail the check, and
# the same token simply works for both. Add to your real .env:
#   SELFROLE_BOT_TOKEN=${DISCORD_BOT_TOKEN}   # self-role — needs Manage Roles
#   TICKETS_BOT_TOKEN=${DISCORD_BOT_TOKEN}    # tickets   — needs Manage Channels + Manage Roles
# Optional one-click invite links shown in each plugin's config UI (their
# permissions are normalized to the shared union — Create Instant Invite + Manage
# Channels + Manage Roles + Manage Webhooks — so a narrower paste can't strip
# another feature's grant):
#   SELFROLE_BOT_INVITE_URL=https://discord.com/oauth2/authorize?client_id=APP_ID&scope=bot&permissions=805306385
#   TICKETS_BOT_INVITE_URL=https://discord.com/oauth2/authorize?client_id=APP_ID&scope=bot&permissions=805306385
# The shared bot must hold Create Instant Invite + Manage Channels + Manage Roles
# + Manage Webhooks (the union DWEEB's plugins, the Send/Restore webhook picker,
# and Collaborate in Discord request). Re-invite through any link to grant them
# at once.

# ── Server ─────────────────────────────────────────────────────────────────
# Address the proxy listens on inside the container. Leave as-is for Docker.
BIND_ADDR=0.0.0.0:8080

# Browser origins allowed to call the proxy (CORS), comma-separated. Because
# auth uses cookies, "*" is NOT allowed — list the builder's EXACT origin(s):
#   ALLOWED_ORIGINS=https://dweeb.example.com
ALLOWED_ORIGINS=http://localhost:5173

# ── Discord Activity (embedded app) ────────────────────────────────────────
# Master switch for the embedded Activity endpoints (/api/activity/token, /post,
# and the /room/:instance collaboration WebSocket). Default on — they reuse the
# OAuth client + bot token already configured above, so no extra secret is
# needed. Set false on a deployment that doesn't register a Discord Activity.
# Setup beyond this is in the Developer Portal (URL mappings + scopes); see
# docs/activity.md.
ACTIVITIES_ENABLED=true

# Host allow-list for the Activity plugin proxy (/api/activity/plugin*). Inside
# Discord a plugin's own *.dweeb.faizo.net config iframe is CSP-blocked, so the
# proxy serves it same-origin and relays its API calls; this list is what keeps
# that from becoming an open proxy. Comma-separated bare domains — a host matches
# when it equals an entry or is a sub-domain of one. Default: the DWEEB plugin
# domain. Change it if you host plugins on your own domain.
ACTIVITY_PLUGIN_HOSTS=dweeb.faizo.net

# Where the Activity's collaboration drafts are persisted, so a room can be
# reopened where it was left off (and survives a proxy restart with no peers
# online to re-seed it). Put this on the SAME persistent volume as SCHEDULE_DB_PATH
# / SHORTLINK_DB_PATH so it outlives a redeploy. Best-effort: if it can't be
# opened the proxy logs and falls back to the old ephemeral behaviour rather than
# failing to boot. Only used when ACTIVITIES_ENABLED=true.
# Leave UNSET for Docker (compose points it at the proxy_data volume); a bare
# `cargo run` then defaults to ./activity-drafts.db. Setting a RELATIVE value here
# would override compose's /data default and silently make drafts ephemeral.
#   ACTIVITY_DRAFT_DB_PATH=/data/activity-drafts.db
# A brand-new instance's draft is dropped once this many are stored (existing
# rows keep updating); bounds worst-case disk use.
ACTIVITY_DRAFT_MAX_ENTRIES=20000
# Days a draft is kept after its last edit before the hourly sweeper deletes it —
# a session nobody has touched this long isn't getting resumed.
ACTIVITY_DRAFT_RETENTION_DAYS=7
# Max concurrent multipart post/edit uploads held in proxy memory. Each request
# may carry up to 32 MiB, so keep this small; saturated uploads get a retryable
# 503 instead of risking an out-of-memory crash. Plain JSON sends are unaffected.
ACTIVITY_UPLOAD_CONCURRENCY=2

# Feedback-forum webhook used by the web builder and embedded Activity. This is
# a credential: keep it only on the proxy. Both browser surfaces submit a small
# report to the proxy, which validates it and relays it here. Only HTTPS Discord
# execute URLs are accepted. Leave blank and both feedback endpoints answer 501.
#   FEEDBACK_WEBHOOK_URL=https://discord.com/api/webhooks/<id>/<token>
FEEDBACK_WEBHOOK_URL=

# ── Authorization policy ───────────────────────────────────────────────────
# When true (default), a user may only read servers they OWN or have
# "Manage Server" in — appropriate for a webhook-builder tool. Set false to
# allow any server they're merely a member of.
REQUIRE_MANAGE_GUILD=true

# ── Caching & abuse controls ───────────────────────────────────────────────
# Seconds to cache each guild's data and each user's server list (default 60).
# The process-local backend is hard-capped at 10,000 entries / ~32 MiB of
# retained JSON; configure REDIS_URL below when scaling across proxy replicas.
CACHE_TTL_SECS=60
# Per-IP request budget for /api + /auth (sustained rate + burst allowance).
RATE_LIMIT_PER_MIN=60
RATE_LIMIT_BURST=20
# Max simultaneous calls to Discord under the shared bot token (global cap).
DISCORD_MAX_CONCURRENCY=10

# ── Short links ────────────────────────────────────────────────────────────
# The builder's opt-in "Create short link" action uploads a share token here
# and serves it back from https://<frontend>/s/<id>. Links auto-expire and
# are deleted after this many days (default 7). Set 0 to disable the feature
# entirely — the endpoints answer 501 and the UI only offers the hash link.
SHORTLINK_TTL_DAYS=7
# SQLite file the links live in. MUST be on persistent storage — a short link
# is a 7-day promise, so it has to survive a redeploy. The Docker image
# defaults to /data/shortlinks.db and compose.yml mounts the proxy_data
# volume there, so leave this unset for Docker deploys. For a bare
# `cargo run` the default is ./shortlinks.db.
#   SHORTLINK_DB_PATH=/data/shortlinks.db
# Storage cap: creation answers 503 once this many links are stored (existing
# links keep resolving until they expire). Bounds worst-case disk usage.
SHORTLINK_MAX_ENTRIES=50000

# ── Scheduled posts ────────────────────────────────────────────────────────
# Post a webhook message later (one-time or recurring). Payloads + destination
# webhook URLs are sealed at rest under SESSION_SECRET, so this needs no secret
# of its own. Default on; set false and the /api/schedules endpoints answer 501,
# the delivery worker never starts, and the builder hides the Schedule toggle.
SCHEDULES_ENABLED=true
# SQLite file the schedules live in. MUST be on persistent storage — a schedule
# is a promise to post at a future time, so it has to survive a redeploy. Leave
# UNSET for Docker (compose points it at the proxy_data volume); a bare
# `cargo run` then defaults to ./schedules.db.
#   SCHEDULE_DB_PATH=/data/schedules.db
# Global storage cap: creation answers 503 once this many schedules are stored.
SCHEDULE_MAX_ENTRIES=5000
# Anti-spam caps on pending (active/paused) schedules, per destination webhook
# and per Discord server. SCHEDULE_MAX_PER_GUILD is the user-facing quota and is
# what the PLAN_*_SCHEDULES tiers below override once Stripe is configured.
SCHEDULE_MAX_PER_WEBHOOK=25
SCHEDULE_MAX_PER_GUILD=5
# How far ahead a first run may be scheduled (days).
SCHEDULE_MAX_HORIZON_DAYS=366
# Days a completed/failed schedule is kept in the management list before the
# worker sweeps it away.
SCHEDULE_RETENTION_DAYS=7
# Delivery worker: how often it wakes to fire due schedules (seconds), how long
# a claimed row is leased before a crashed worker's claim is retried, and the
# most it will fire in one tick (bounds the Discord call rate after a backlog).
SCHEDULER_TICK_SECS=15
SCHEDULER_LEASE_SECS=120
SCHEDULER_BATCH=25

# ── Durable storage guard ──────────────────────────────────────────────────
# Every *_DB_PATH above holds a durable promise (a post that must fire, a saved
# draft, a 7-day link, the billing mirror). A RELATIVE path resolves against the
# process's working directory — inside a container that is the image's writable
# layer, NOT the mounted volume, so the file is destroyed on the next deploy and
# the data is gone with no error. The proxy logs a loud warning at boot if any
# enabled store has a relative path. Set this to true in production, once every
# path is absolute, to turn that warning into a hard boot failure.
STRICT_DB_PATHS=false

# ── Message library ────────────────────────────────────────────────────────
# The per-server message library: every message a manager posts (and any draft
# they save) lands on one shared, labelled shelf per Discord server, readable
# from the web app AND the embedded Activity. Payloads + webhook URLs are
# sealed at rest under SESSION_SECRET, like scheduled posts. Default on; set
# false and the /api/guilds/:id/library endpoints answer 501 (both frontends
# then fall back to browser-local storage only).
LIBRARY_ENABLED=true
# SQLite file the library lives in. MUST be on persistent storage — a saved
# message is a promise to keep it. Docker deploys should point this at the
# same volume as the schedule/short-link DBs:
#   LIBRARY_DB_PATH=/data/library.db
# Bare `cargo run` defaults to ./library.db.
# Global storage cap: creation answers 503 once this many entries are stored
# (existing ones stay readable). Bounds worst-case disk usage.
LIBRARY_MAX_ENTRIES=100000
# The two labels are quota'd separately. Saved drafts are a hard cap (full =
# save refused); posted history is a rolling window (recording a post past it
# evicts the oldest record instead of failing). These are the standalone
# defaults used when the plan system is NOT configured; with Stripe configured,
# the per-tier PLAN_*_LIBRARY / PLAN_*_LIBRARY_POSTED quotas below apply
# instead.
LIBRARY_MAX_PER_GUILD=100
LIBRARY_POSTED_PER_GUILD=100

# ── Built-in AI (optional, Groq-backed) ────────────────────────────────────
# The AI assistant's no-key mode: the proxy holds ONE Groq API key and relays
# chat completions for signed-in users, with per-user/per-server daily quotas
# (see the PLAN_*_AI_* tiers below) and a monthly deployment-wide token budget.
# Unset ⇒ the /api/ai endpoints answer 501 and the FE hides the built-in
# provider (bring-your-own-key still works). This is a CREDENTIAL — it must
# never appear in a frontend build (no VITE_* variant exists on purpose).
GROQ_API_KEY=
# The pinned chat model (clients can never choose one) and an optional cheaper
# fallback tried once when the primary is unavailable (429/5xx after a retry).
AI_MODEL=openai/gpt-oss-120b
AI_FALLBACK_MODEL=llama-3.1-8b-instant
# OpenAI-compatible API origin the relay calls. Default Groq; override only to
# point at a mock/proxy.
#   AI_BASE_URL=https://api.groq.com/openai/v1
# max_tokens pinned on every completion — bounds the cost of one reply. NOTE:
# Groq counts this RESERVED budget toward its per-minute token limit (TPM), not
# just tokens generated — so it must stay well under the smallest Groq tier's
# TPM you target. The free tier's 8k TPM is breached by an 8k reservation
# ALONE (every request 413s); the Developer tier is ~10x higher. 4k fits a full
# Components V2 message plus prompt on free, with lots of headroom on Dev.
AI_MAX_TOKENS=4096
# SQLite file the usage ledger lives in. MUST be on persistent storage — quotas
# that reset on every redeploy aren't quotas. Docker deploys:
#   AI_DB_PATH=/data/ai-usage.db
# Bare `cargo run` defaults to ./ai-usage.db.
# Simultaneous relayed provider streams (the shared lane), plus extra permits
# only paid servers may spill into when the shared lane is full — the "premium
# keeps working under load" lever.
AI_CONCURRENCY=4
AI_RESERVED_CONCURRENCY=2
# Monthly deployment-wide token ceiling (input + output, all users combined).
# Once spent, built-in AI answers a distinct 503 until the next UTC month and
# the FE steers users to bring-your-own-key — the hard cap on what the feature
# can ever cost, and the only thing bounding the (revenue-free) Free tier in
# aggregate. Blended cost is ~$0.30 per 1M tokens on gpt-oss-120b at our
# input/output mix, so: max $/month ≈ budget ÷ 1M × $0.30.
#   20M ≈ $6/mo    40M ≈ $12/mo    100M ≈ $30/mo
# Keep this comfortably above the sum of your paid servers' realistic use, or
# one heavy server starves everyone else for the rest of the month.
# 0 = uncapped (never do this in production).
AI_MONTHLY_TOKEN_BUDGET=20000000

# ── Scaling (optional) ─────────────────────────────────────────────────────
# Leave blank for a single instance (in-memory cache + rate limiter). Set a
# Redis URL to SHARE the cache and rate-limit counters across multiple proxy
# instances behind a load balancer. The proxy verifies the connection at boot
# and exits if it can't reach Redis.
#   REDIS_URL=redis://127.0.0.1:6379
#   REDIS_URL=redis://:password@redis-host:6379
REDIS_URL=

# Async runtime size. The proxy is I/O-bound (it mostly awaits Discord), so the
# default of one worker per CPU just reserves idle thread stacks and per-thread
# allocator arenas. Defaults to 2 — enough to overlap the parallel hot-path
# reads. Raise it only if the CPU is genuinely saturated.
#   TOKIO_WORKER_THREADS=2
# Connections in each SQLite store's pool (default 3, floor 1). WAL allows
# concurrent readers, and a pool keeps them from serializing behind one lock.
# Each connection carries its own page + statement cache, so on a
# memory-constrained host set this to 1 to get the old single-connection
# behaviour back.
#   SQLITE_POOL_SIZE=3

# Log verbosity: error | warn | info | debug | trace
RUST_LOG=info

# ── Monitoring (Docker deploys only) ───────────────────────────────────────
# Optional self-hosted stack: Beszel (metrics), Gatus (uptime), Dozzle (logs).
# See server/MONITORING.md for the 5-minute first-run setup. Leave every value
# below blank to run the core stack WITHOUT monitoring — the containers simply
# idle until configured and nothing else changes.
#
# Discord webhook Gatus posts uptime alerts to (Discord → Server Settings →
# Integrations → Webhooks → New Webhook → Copy URL). Beszel's own alerts are
# wired up separately inside its UI (MONITORING.md explains). Blank = Gatus
# still runs and shows the status page, it just doesn't send alerts.
MONITORING_DISCORD_WEBHOOK=
# Beszel agent ↔ hub credentials, both shown by the hub UI on first run: open
# https://beszel.$PLUGINS_DOMAIN, create the admin user, then "Add System" →
# Docker (KEY) and Settings → Tokens (TOKEN). Paste them here, then start the
# agent (it's behind a compose profile so it can't crash-loop before it's set):
#   docker compose --profile beszel-agent up -d beszel-agent
#   BESZEL_KEY   = the hub's public key (starts with "ssh-ed25519 …")
#   BESZEL_TOKEN = a universal token from Settings → Tokens
BESZEL_KEY=
BESZEL_TOKEN=

# ── Plans & billing (DWEEB's Stripe integration, PER-SERVER, BUNDLED) ───────
# Premium is sold PER DISCORD SERVER (MEE6/Dyno-style): a subscription is bound to
# one guild (stamped as subscription metadata at checkout) and raises THAT
# server's quotas. DWEEB reads Stripe DIRECTLY — its own embedded Checkout,
# webhook, and local subscription mirror. It shares the SAME Stripe account +
# price IDs as the sibling RoleLogic app ON PURPOSE: one subscription is
# recognised by BOTH apps, so a single payment grants RoleLogic (per user) AND
# DWEEB (per bound server) — a combined bundle. There is still no runtime
# dependency on RoleLogic. Leave STRIPE_SECRET_KEY blank and the whole plan
# system is inert (every server Free, gates use their defaults) — standalone.
#
# Secret + webhook signing key from the Stripe dashboard. Register a webhook
# endpoint pointing at  <API_BASE>/api/stripe/webhook  and subscribe to:
#   checkout.session.completed, customer.subscription.created / updated / deleted,
#   invoice.payment_failed
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# price_id -> entitlement slots — the prices DWEEB RECOGNISES. JSON. A server's
# tier is the sum of the slots of the subscriptions bound to it: >=130 Pro, >=36
# Plus, else Free. Use the SHARED RoleLogic price->slot map (its ROLES_QUOTA):
# recognising RoleLogic's own prices is what makes one subscription grant both
# apps AND lets an existing RoleLogic subscriber's sub auto-apply to ONE DWEEB
# server on first use (movable afterwards).
#   STRIPE_PRICE_SLOTS={"price_medium":36,"price_medium_yr":36,"price_large":74,"price_expanded":130,"price_expanded_yr":130,"price_maximized":208}
STRIPE_PRICE_SLOTS=
# Which price the in-app "Upgrade" buttons buy for each DWEEB tier. Point these
# at the SHARED RoleLogic tier whose amount matches the modal: Plus = RoleLogic
# Medium ($5 / $50, 36 slots), Pro = RoleLogic Expanded ($10 / $100, 130 slots).
# Buying either creates a normal RoleLogic subscription that also premiums the
# chosen DWEEB server. The _YEAR variants power the Monthly/Annual toggle (annual
# optional — without them the toggle only offers monthly).
STRIPE_CHECKOUT_PRICE_PLUS=
STRIPE_CHECKOUT_PRICE_PRO=
STRIPE_CHECKOUT_PRICE_PLUS_YEAR=
STRIPE_CHECKOUT_PRICE_PRO_YEAR=
# Optional fixed TaxRate id (txr_...) added on top at checkout. Blank = no tax line.
STRIPE_TAX_RATE_ID=
# SQLite file for the local subscription mirror (persistent volume, like the
# schedule/short-link DBs). Default stripe.db.
STRIPE_DB_PATH=
# How long before re-searching Stripe for a SERVER with no mirrored subscription
# (bounds the per-guild backfill of subs that predate/missed the webhook).
# Default 86400.
STRIPE_BACKFILL_TTL_SECS=86400
# How long a resolved tier is cached per server before re-reading the mirror.
ENTITLEMENT_CACHE_SECS=300
# Per-tier quotas (all optional — these are the shipped defaults). 0 = unlimited.
#   PLAN_FREE_SCHEDULES=3   PLAN_PLUS_SCHEDULES=30   PLAN_PRO_SCHEDULES=0
#   PLAN_FREE_PERMANENT=5   PLAN_PLUS_PERMANENT=25   PLAN_PRO_PERMANENT=0
#   PLAN_FREE_LIBRARY=10    PLAN_PLUS_LIBRARY=100    PLAN_PRO_LIBRARY=0
#   PLAN_FREE_LIBRARY_POSTED=10  PLAN_PLUS_LIBRARY_POSTED=100  PLAN_PRO_LIBRARY_POSTED=0
#   PLAN_FREE_CUSTOM_BOTS=1 PLAN_PLUS_CUSTOM_BOTS=2  PLAN_PRO_CUSTOM_BOTS=5
#   PLAN_FREE_COEDITORS=2   PLAN_PLUS_COEDITORS=6    PLAN_PRO_COEDITORS=25
# Built-in AI, per UTC day. Free is a PER-USER allowance; Plus/Pro are POOLED
# per server (with a per-member ceiling so one member can't drain the pool).
# Nothing here is unlimited — AI spends real provider money per request.
#
# COSTING THESE: on gpt-oss-120b ($0.15/M in, $0.60/M out) one request costs
# ~$0.002 worst case, so every request-per-day you grant costs ~$0.06/month.
# The shipped defaults keep a maxed-out server at ~25% of its net subscription
# revenue, so a paid server is profitable even if it maxes out every day:
#   Free  8/day  -> ~$0.48/mo per ACTIVE user (no revenue - keep this small)
#   Plus  20/day -> ~$1.20/mo vs ~$4.55 net
#   Pro   40/day -> ~$2.40/mo vs ~$9.41 net
# Request caps bind first; the token caps are the backstop against a few
# huge-context requests burning the allowance. NB: one chat message can cost
# up to 3 requests (initial + missing-payload nudge + validation repair).
#   PLAN_FREE_AI_REQUESTS=8    PLAN_PLUS_AI_REQUESTS=20     PLAN_PRO_AI_REQUESTS=40
#   PLAN_FREE_AI_TOKENS=60000  PLAN_PLUS_AI_TOKENS=150000   PLAN_PRO_AI_TOKENS=300000
#   PLAN_PLUS_AI_MEMBER_REQUESTS=10   PLAN_PRO_AI_MEMBER_REQUESTS=20
