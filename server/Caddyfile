# TLS-terminating edge for the proxy and the plugin services, used by
# compose.yml. Caddy obtains and renews every Let's Encrypt certificate
# automatically — each hostname's DNS must point STRAIGHT at this host
# (Cloudflare proxy OFF / "DNS only"), or the ACME challenge can't reach us.
# Serves HTTP/1.1 + HTTP/2 + HTTP/3 (QUIC).
{
	email {$ACME_EMAIL}
}

# Shared site defaults: compress JSON/HTML (zstd/gzip, negotiated — small CPU
# cost, less time on the wire) and pin HTTPS.
(site_defaults) {
	encode zstd gzip
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		# These hosts serve APIs, interaction endpoints, plugin configuration
		# iframes, and operational dashboards — never public discovery content.
		# Keep them out of search indexes even when an HTML route returns 200.
		X-Robots-Tag "noindex, nofollow, noarchive"
	}
}

# The Discord app's single Interactions Endpoint URL — its own hostname under
# the plugins wildcard, so it NEVER moves when plugins come and go. The
# dispatcher verifies the signature and fans out to plugins by custom_id
# prefix.
interactions.{$PLUGINS_DOMAIN} {
	import site_defaults
	# The management APIs are internal (proxy → dispatcher over the compose
	# network, bearer-token gated). Don't expose them at the edge.
	handle /permanent* {
		respond 404
	}
	handle /custom-apps* {
		respond 404
	}
	handle {
		reverse_proxy dispatcher:8095
	}
}

{$DOMAIN} {
	import site_defaults

	# Alias for the dispatcher (canonical URL above, which serves at "/").
	handle /interactions {
		rewrite * /
		reverse_proxy dispatcher:8095
	}

	handle {
		reverse_proxy proxy:8080 {
			# The app trusts CF-Connecting-IP / X-Real-IP first when
			# picking the client IP for per-IP rate limiting. Nothing
			# in front of Caddy sets these anymore, so strip them —
			# otherwise any client could spoof its rate-limit
			# identity. Caddy itself overwrites X-Forwarded-For with
			# the real client IP.
			header_up -CF-Connecting-IP
			header_up -X-Real-IP
		}
	}
}

# ── Plugins ──────────────────────────────────────────────────────────────────
# Convention: every plugin is served at <id>.{$PLUGINS_DOMAIN}. The wildcard
# DNS record (*.{$PLUGINS_DOMAIN} → this host, DNS only) and the builder's CSP
# (frame-src https://*.{$PLUGINS_DOMAIN}) already cover ANY subdomain, so a new
# plugin needs no DNS or CSP work — copy a block, change subdomain + upstream,
# and register its custom_id prefix in the dispatcher's ROUTES (compose.yml).

# Modal Form.
modalform.{$PLUGINS_DOMAIN} {
	import site_defaults
	reverse_proxy modal-form:8090
}

# Ping Pong.
pingpong.{$PLUGINS_DOMAIN} {
	import site_defaults
	reverse_proxy ping-pong:8091
}

# Self Role.
selfrole.{$PLUGINS_DOMAIN} {
	import site_defaults
	reverse_proxy self-role:8092
}

# Tickets.
tickets.{$PLUGINS_DOMAIN} {
	import site_defaults
	reverse_proxy tickets:8093
}

# Giveaway.
giveaway.{$PLUGINS_DOMAIN} {
	import site_defaults
	reverse_proxy giveaway:8094
}

# Quick Replies.
quickreplies.{$PLUGINS_DOMAIN} {
	import site_defaults
	reverse_proxy quick-replies:8096
}

# Picker.
picker.{$PLUGINS_DOMAIN} {
	import site_defaults
	reverse_proxy picker:8097
}

# Poll.
poll.{$PLUGINS_DOMAIN} {
	import site_defaults
	reverse_proxy poll:8098
}

# ── Monitoring ───────────────────────────────────────────────────────────────
# Self-hosted monitoring UIs on the plugins wildcard (no DNS work). Dozzle (raw
# container logs) is intentionally absent — it stays localhost-only and is
# reached over an SSH tunnel (see compose.yml) so logs never touch the internet.
# If a monitoring container is down these blocks just return 502; they can't
# affect the proxy or dispatcher.

# Beszel — metrics dashboard (protected by its own login).
beszel.{$PLUGINS_DOMAIN} {
	import site_defaults
	reverse_proxy beszel:8090
}

# Gatus — uptime status page (read-only; safe to be public).
status.{$PLUGINS_DOMAIN} {
	import site_defaults
	reverse_proxy gatus:8080
}
